@page "/"

<PageTitle>Chase Bonham — Portfolio</PageTitle>

@using MudBlazor
@using Portfolio.Data
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<ApplicationDbContext> DbFactory

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-16">
    <MudGrid Justify="Justify.Center" Class="py-16">
        <MudItem xs="12" md="8">
            <MudChip T="string" Color="Color.Primary" Variant="Variant.Text" Class="ml-0 mb-4">
                Operations & Software Development
            </MudChip>
            <MudText Typo="Typo.h1" Class="text-primary" Style="line-height: 1;">
                Chase
            </MudText>
            <MudText Typo="Typo.h1" Class="name-accent">
                Bonham
            </MudText>
            <MudText Typo="Typo.h5" Class="mud-text-secondary mt-6" Style="max-width: 600px;">
                Full-stack engineer & operations specialist. I build software, design infrastructure, and manage people. Passionate about creating elegant digital solutions supported by robust, real-world operational systems.
            </MudText>
            <div class="d-flex gap-4 mt-10">
                <MudButton Href="#projects" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" EndIcon="@Icons.Material.Filled.ArrowForward">
                    View Projects
                </MudButton>
                <MudButton Href="#contact" Variant="Variant.Outlined" Color="Color.Default" Size="Size.Large">
                    Get in Touch
                </MudButton>
            </div>
        </MudItem>
        
        <MudItem xs="12" md="4" Class="d-flex flex-column justify-center">
            <div class="d-flex flex-column gap-8">
                <StatItem Number="@_projects.Count().ToString()" Suffix="+" Label="Projects" />
                <StatItem Number="@yearsOfExperience" Suffix="years" Label="Experience" />
            </div>
        </MudItem>
    </MudGrid>

    <section id="projects" class="mt-16">
        <div class="d-flex align-center mb-8">
            <MudText Typo="Typo.h6" Class="mr-4" Style="opacity: 0.5;">01</MudText>
            <MudText Typo="Typo.h3">Projects</MudText>
            <MudDivider Class="flex-grow-1 ml-4" DividerType="DividerType.Middle" />
        </div>

        <MudGrid Class="mt-4">
            @foreach (var Project in _projects)
            {
                <MudItem xs="12" md="6">
                    <MudCard Elevation="4" Class="pa-4" Style="height: 100%; border-top: 4px solid var(--mud-palette-primary);">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudGrid Justify="Justify.SpaceBetween">
                                    <MudItem>
                                        <MudText Typo="Typo.caption">
                                            @Project.ID.ToString("D3")
                                            @if(Project.ParentProject != null) {
                                                <text> - <MudText Typo="Typo.caption" class="name-accent">@Project.ParentProject.Name</MudText></text>
                                            }
                                        </MudText>
                                        <MudText Typo="Typo.h5">@Project.Name</MudText>
                                    </MudItem>
                                    <MudText Typo="Typo.caption">@Project.DatePublished.ToString("MM/dd/yyyy")</MudText>
                                </MudGrid>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudText Typo="Typo.body2">@Project.Description</MudText>
                            <div class="d-flex flex-wrap gap-2 mt-4">
                                @foreach(Tag tag in Project.Tags)
                                {
                                    <MudChip T="string" Variant="Variant.Text" Style="@($"color: {tag.ColorHex} !important; border: 1px solid {tag.ColorHex} !important;")" Size="Size.Small">
                                        @tag.Name
                                    </MudChip>
                                }
                            </div>
                        </MudCardContent>
                        <MudCardActions>
                            @if (!string.IsNullOrWhiteSpace(Project.GitHubURL))
                            {
                                <MudIconButton href="@Project.GitHubURL" Target="_blank" Icon="@Icons.Custom.Brands.GitHub" Color="Color.Default" />
                            }
                            @if (!string.IsNullOrWhiteSpace(Project.URL))
                            {
                                <MudButton href="@Project.URL" Target="_blank" Variant="Variant.Text" Color="Color.Primary" EndIcon="@Icons.Material.Filled.Launch">Link</MudButton>
                            }
                        </MudCardActions>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    </section>

    <section id="timeline" class="mt-16">
        <div class="d-flex align-center mb-8">
            <MudText Typo="Typo.h6" Class="mr-4" Style="opacity: 0.5;">02</MudText>
            <MudText Typo="Typo.h3">Timeline</MudText>
            <MudDivider Class="flex-grow-1 ml-4" DividerType="DividerType.Middle" />
        </div>

        <MudTimeline TimelinePosition="TimelinePosition.Start">
            @foreach (var Milestone in _milestones)
            {
                <MudTimelineItem Color="@(Milestone.DateEnd == null ? Color.Primary : Color.Secondary)"
                                 Size="Size.Small"
                                 Variant="Variant.Filled">
                    <ItemContent>
                        <MudPaper Elevation="0" Class="pa-4 mud-background-gray">
                            <div class="d-flex align-center justify-space-between mb-2">
                                <div class="d-flex align-center">
                                    <MudIcon Icon="@Milestone.milestoneType.Icon"
                                             Size="Size.Small"
                                             Class="mr-2" />
                                    <MudChip T="string"
                                             Size="Size.Small"
                                             Color="@(Milestone.DateEnd == null ? Color.Primary : Color.Secondary)"
                                             Variant="Variant.Text"
                                             Class="ma-0">
                                        @Milestone.milestoneType.Name
                                    </MudChip>
                                </div>

                                <MudText Typo="Typo.caption" Class="mud-text-secondary font-weight-bold">
                                    @Milestone.DateStart?.ToString("MMM yyyy")@((Milestone.DateEnd.HasValue) ? $" — {Milestone.DateEnd.Value.ToString("MMM yyyy")}" : " — Present")
                                </MudText>
                            </div>

                            <MudText Typo="Typo.h6">@Milestone.Title</MudText>
                            <MudText Typo="Typo.subtitle2" Class="mud-text-secondary">@Milestone.Subtitle</MudText>

                            @if (!string.IsNullOrEmpty(Milestone.Description))
                            {
                                <MudText Typo="Typo.body2" Class="mt-2">
                                    @Milestone.Description
                                </MudText>
                            }
                        </MudPaper>
                    </ItemContent>
                </MudTimelineItem>
            }
        </MudTimeline>
    </section>

    <section id="contact" class="mt-16 py-16">
        <div class="d-flex align-center mb-8">
            <MudText Typo="Typo.h6" Class="mr-4" Style="opacity: 0.5;">04</MudText>
            <MudText Typo="Typo.h3">Contact</MudText>
            <MudDivider Class="flex-grow-1 ml-4" DividerType="DividerType.Middle" />
        </div>

        <MudGrid>
            <MudItem xs="12" md="5">
                <MudText Typo="Typo.h5" Class="mb-6">
                    I am always open to fresh perspectives. If you're passionate about building, let's connect.
                </MudText>
            </MudItem>
            <MudItem xs="12" md="7">
                <MudStack Spacing="0">
                    <MudCard>
                        <MudCardContent>
                            <MudGrid>
                                <MudItem xs="12" sm="1">
                                    <MudIcon Icon="@Icons.Material.Filled.Email" />
                                </MudItem>
                                <MudItem xs="12" sm="11">
                                    <MudText Typo="Typo.h6">EMAIL</MudText>
                                    <MudLink Href="mailto:chase@chasebonham.com">Chase@ChaseBonham.com</MudLink>
                                </MudItem>
                            </MudGrid>
                        </MudCardContent>

                        <MudDivider />

                        <MudCardContent>
                            <MudGrid>
                                <MudItem xs="12" sm="1">
                                    <MudIcon Icon="@Icons.Custom.Brands.LinkedIn" />
                                </MudItem>
                                <MudItem xs="12" sm="11">
                                    <MudText Typo="Typo.h6">LINKEDIN</MudText>
                                    <MudLink Href="https://www.linkedin.com/in/chase-bonham/" Target="_blank">Chase Bonham</MudLink>
                                </MudItem>
                            </MudGrid>
                        </MudCardContent>

                        <MudDivider />

                        <MudCardContent>
                            <MudGrid>
                                <MudItem xs="12" sm="1">
                                    <MudIcon Icon="@Icons.Material.Filled.Assignment" />
                                </MudItem>
                                <MudItem xs="12" sm="11">
                                    <MudText Typo="Typo.h6">RESUME</MudText>
                                    <MudLink Href="path_to_resume.pdf" Target="_blank">Download PDF</MudLink>
                                </MudItem>
                            </MudGrid>
                        </MudCardContent>
                    </MudCard>
                    <MudDivider />
                </MudStack>
            </MudItem>
        </MudGrid>
    </section>
    
    <MudDivider Class="mt-16 opacity-20" />
    <footer class="d-flex justify-space-between align-center py-12 px-4">
        <MudItem>
            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                © @DateTime.UtcNow.Year Chase Bonham
            </MudText>
            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                View source code on <MudIconButton Icon="@Icons.Custom.Brands.GitHub"
                                                   Href="https://github.com/ItsChase88/Portfolio"
                                                   Target="_blank"
                                                   Size="Size.Small" />
            </MudText>
        </MudItem>

        <MudLink href="#" Color="Color.Default" Underline="Underline.None" Class="d-flex align-center gap-2">
            <MudText Typo="Typo.body2">Back to top</MudText>
            <MudIcon Icon="@Icons.Material.Filled.ArrowUpward" Size="Size.Small" />
        </MudLink>
    </footer>

</MudContainer>


@code {
    private String yearsOfExperience = (DateTime.UtcNow.Year - 2021).ToString();

    private List<Project> _projects = new();
    private List<Milestone> _milestones = new();

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        _projects = await context.Projects.Include(p => p.Tags).ToListAsync();
        _milestones = await context.Milestones
            .Include(p => p.milestoneType)
            .OrderByDescending(p => p.DateEnd == null)
            .ThenByDescending(p => p.DateEnd)
            .ToListAsync();
    }
}