@using MudBlazor.Utilities
@using Portfolio.Data
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<ApplicationDbContext> DbFactory

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">@MudDialog.Title</MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField Label="Name" @bind-Value="Project.Name" Required="true" />
        <MudTextField Label="Description" @bind-Value="Project.Description" Lines="3" />
        <MudTextField Label="Demo URL" @bind-Value="Project.URL" />
        <MudTextField Label="GitHub URL" @bind-Value="Project.GitHubURL" />
        <MudSelect T="int?" Label="Parent Project" @bind-Value="Project.ParentProjectID">
            @foreach (var project in _parentProjectOptions)
            {
                <MudSelectItem T="int?" Value="@project.ID">@project.Name</MudSelectItem>
            }
        </MudSelect>
        <MudSelect T="int" Label="Tags" MultiSelection="true" @bind-SelectedValues="_selectedTagIds">
            <SelectValuePresenter>
                <div class="d-flex flex-wrap gap-1">
                    @foreach (var id in _selectedTagIds)
                    {
                        <MudChip T="string" Variant="Variant.Text" Style="@($"color: {_availableTags.FirstOrDefault(x => x.ID == id)?.ColorHex}; border: 1px solid {_availableTags.FirstOrDefault(x => x.ID == id)?.ColorHex};")" Size="Size.Small">
                            @(_availableTags.FirstOrDefault(x => x.ID == id)?.Name)
                        </MudChip>
                    }
                </div>
            </SelectValuePresenter>
            @foreach (var tag in _availableTags)
            {
                <MudSelectItem T="int" Value="@tag.ID">@tag.Name</MudSelectItem>
            }
        </MudSelect>
        <MudDatePicker Label="Date Published" @bind-Date="DateProperty" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public Project Project { get; set; } = new();

    private List<Project> _parentProjectOptions = new();

    private List<Tag> _availableTags = new();
    private IEnumerable<int> _selectedTagIds = new HashSet<int>();

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        _parentProjectOptions = await context.Projects
                                    .Include(x => x.ParentProject)
                                    .Where(x => x.ID != Project.ID)
                                    .ToListAsync();

        _availableTags = await context.Tags.ToListAsync();

        if (Project.Tags != null)
        {
            _selectedTagIds = new HashSet<int>(Project.Tags.Select(t => t.ID));
        }
    }

    private DateTime? DateProperty
    {
        get => Project.DatePublished;
        set => Project.DatePublished = value ?? DateTime.Now;
    }

    private void Cancel() => MudDialog.Cancel();

    private void Submit()
    {
        Project.Tags = _availableTags
                        .Where(t => _selectedTagIds.Contains(t.ID))
                        .ToList();

        MudDialog.Close(DialogResult.Ok(Project));
    }
}