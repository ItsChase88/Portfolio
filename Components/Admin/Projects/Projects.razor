@page "/admin/projects"
@using Portfolio.Data
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-16">
    <MudText Typo="Typo.h4" Class="mb-4">Project Management</MudText>

    <MudDataGrid Items="@_projects" T="Project" Hover="true">
        <ToolBarContent>
            <MudText Typo="Typo.h6">All Projects</MudText>
            <MudSpacer />
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add"
                       OnClick="@((e) => OpenDialog(new Project()))">
                Add Project
            </MudButton>
        </ToolBarContent>
        <Columns>
            <PropertyColumn Property="x => x.Name" Title="Name" />
            <PropertyColumn Property="x => x.ParentProject!.Name" Title="Parent Project" />
            <PropertyColumn Property="x => x.URL" Title="Link" />
            <PropertyColumn Property="x => x.GitHubURL" Title="Github" />
            <PropertyColumn Property="x => x.DatePublished" Format="MM/dd/yyyy" Title="Date Published" />
            <TemplateColumn CellClass="d-flex justify-end">
                <CellTemplate>
                    <MudIconButton Size="@Size.Small" Icon="@Icons.Material.Filled.Edit"
                                   OnClick="@((e) => OpenDialog(context.Item))" />
                    <MudIconButton Size="@Size.Small" Icon="@Icons.Material.Filled.Delete" Color="Color.Error"
                                   OnClick="@((e) => DeleteProject(context.Item))" />
                </CellTemplate>
            </TemplateColumn>
        </Columns>
    </MudDataGrid>
</MudContainer>

@code {
    private List<Project> _projects = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadProjects();
    }

    private async Task LoadProjects()
    {
        using var context = DbFactory.CreateDbContext();
        _projects = await context.Projects.Include(x => x.ParentProject).ToListAsync();
    }

    private async Task OpenDialog(Project project)
    {
        var parameters = new DialogParameters<ProjectDialog> { { x => x.Project, project } };
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };

        var dialog = await DialogService.ShowAsync<ProjectDialog>(project.ID == 0 ? "Add Project" : "Edit Project", parameters, options);
        var result = await dialog.Result;

        if (!result.Canceled && result.Data is Project updatedProject)
        {
            await SaveProject(updatedProject);
        }
    }

    private async Task SaveProject(Project project)
    {
        using var context = DbFactory.CreateDbContext();

        if (project.ID == 0)
        {
            context.Projects.Add(project);
            Snackbar.Add("Project added successfully!", Severity.Success);
        }
        else
        {
            context.Projects.Update(project);
            Snackbar.Add("Project updated successfully!", Severity.Success);
        }

        await context.SaveChangesAsync();
        await LoadProjects();
    }

    private async Task DeleteProject(Project project)
    {
        bool? confirm = await DialogService.ShowMessageBox("Delete Project",
            $"Are you sure you want to delete {project.Name}?", "Delete", "Cancel");

        if (confirm == true)
        {
            using var context = DbFactory.CreateDbContext();
            context.Projects.Remove(project);
            await context.SaveChangesAsync();
            await LoadProjects();
            Snackbar.Add("Project deleted.", Severity.Info);
        }
    }
}