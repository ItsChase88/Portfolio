@using MudBlazor.Utilities
@using Portfolio.Data
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Hosting
@inject IWebHostEnvironment Environment
@inject ISnackbar Snackbar
@inject IDbContextFactory<ApplicationDbContext> DbFactory

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">@MudDialog.Title</MudText>
    </TitleContent>
    <DialogContent>
        <MudFileUpload T="IBrowserFile" Accept=".pdf" FilesChanged="UploadFiles">
            <ActivatorContent>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.CloudUpload">
                    Choose file
                </MudButton>
            </ActivatorContent>
            <SelectedTemplate />
        </MudFileUpload>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public Resume Resume { get; set; } = new();

    private async Task UploadFiles(IBrowserFile file)
    {
        if (file == null) return;

        try
        {
            var extension = Path.GetExtension(file.Name).ToLower();
            if (extension != ".pdf")
            {
                Snackbar.Add("ERROR: Only PDF files can be uploaded.", Severity.Error);
                return;
            }

            var folderPath = Path.Combine(Environment.WebRootPath, "uploads/resumes");

            if (!Directory.Exists(folderPath))
            {
                throw new DirectoryNotFoundException(folderPath);
            }

            var fileName = $"Bonham_Robert Chase Resume {DateTime.Now.ToString("MM-dd-yyyy")}";
            var fullFileName = fileName + Path.GetExtension(file.Name);
            var fullPath = Path.Combine(folderPath, fullFileName);
            var relativePath = $"/uploads/resumes/{fullFileName}";

            long maxAllowedSize = 1024 * 1024 * 10;

            await using var readStream = file.OpenReadStream(maxAllowedSize);
            await using var writeStream = new FileStream(fullPath, FileMode.Create);

            await readStream.CopyToAsync(writeStream);

            Resume.File = relativePath;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error uploading file: {ex.Message}");
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private void Submit()
    {
        MudDialog.Close(DialogResult.Ok(Resume));
    }
}